Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"qx", ",", "qy"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", "\[Mu]c", ",", "\[Mu]f", ",", "tf", ",", "Jk"}], 
    "}"}], "=", 
   RowBox[{"list", "[", 
    RowBox[{"[", "123", "]"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tc", "=", "1"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tc1", "=", "0.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tc2", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tc3", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"L", "=", "31"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ekc", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "2"}], " ", "tc", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", "kx", "]"}], "+", 
       RowBox[{"Cos", "[", "ky", "]"}]}], ")"}]}], "-", 
    RowBox[{"4", 
     RowBox[{"(", "tc1", ")"}], 
     RowBox[{"Cos", "[", "kx", "]"}], 
     RowBox[{"Cos", "[", "ky", "]"}]}], "-", 
    RowBox[{"2", " ", "tc2", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"2", "kx"}], "]"}], "+", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "ky"}], "]"}]}], ")"}]}], "-", 
    RowBox[{"4", "tc3", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"2", "kx"}], "]"}], 
        RowBox[{"Cos", "[", "ky", "]"}]}], "+", 
       RowBox[{
        RowBox[{"Cos", "[", "kx", "]"}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"2", "ky"}], "]"}]}]}], ")"}]}], "-", "\[Mu]c"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ekf", "=", 
    RowBox[{
     RowBox[{"-", "\[Mu]f"}], "+", 
     RowBox[{"2", " ", "tf", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Cos", "[", "kx", "]"}], "+", 
        RowBox[{"Cos", "[", "ky", "]"}]}], ")"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"hybridized", " ", "bands"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"E1", "=", 
   RowBox[{
    FractionBox[
     RowBox[{"ekc", "+", "ekf"}], "2"], "+", 
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"ekc", "-", "ekf"}], "2"], ")"}], "2"], "+", 
      SuperscriptBox["\[Phi]", "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"E2", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"ekc", "+", "ekf"}], "2"], "-", 
     SqrtBox[
      RowBox[{
