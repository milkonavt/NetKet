    RowBox[{"L", "=", "48"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ekc", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "tc", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", "kx", "]"}], "+", 
         RowBox[{"Cos", "[", "ky", "]"}]}], ")"}]}], "-", 
      RowBox[{"4", 
