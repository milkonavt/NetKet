        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"ekc", "-", "ekf"}], "2"], ")"}], "2"], "+", 
        SuperscriptBox["m", "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E2", "=", 
