Cell[CellGroupData[{

Cell["AF order ", "Subsubsection",
 CellChangeTimes->{{3.983932325017008*^9, 
  3.9839323286846724`*^9}},ExpressionUUID->"07a34f95-19bd-4093-b0ee-\
71bf7de31214"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]c", "=", 
     RowBox[{"-", "0.6424145680426989`"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tc", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tc1", "=", 
     RowBox[{"-", "0.0"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tc2", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tc3", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", "4"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"L", "=", "31"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ekc", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "tc", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", "kx", "]"}], "+", 
         RowBox[{"Cos", "[", "ky", "]"}]}], ")"}]}], "-", 
      RowBox[{"4", 
       RowBox[{"(", "tc1", ")"}], 
       RowBox[{"Cos", "[", "kx", "]"}], 
       RowBox[{"Cos", "[", "ky", "]"}]}], "-", 
      RowBox[{"2", " ", "tc2", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"2", "kx"}], "]"}], "+", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "ky"}], "]"}]}], ")"}]}], "-", 
      RowBox[{"4", "tc3", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"2", "kx"}], "]"}], 
          RowBox[{"Cos", "[", "ky", "]"}]}], "+", 
         RowBox[{
          RowBox[{"Cos", "[", "kx", "]"}], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "ky"}], "]"}]}]}], ")"}]}], "-", "\[Mu]c"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ekf", "=", 
     RowBox[{
      RowBox[{"ekc", "/.", 
       RowBox[{"kx", "->", 
        RowBox[{"kx", "+", "\[Pi]"}]}]}], "/.", 
      RowBox[{"ky", "->", 
       RowBox[{"ky", "+", "\[Pi]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", "0.3"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"hybridized", " ", "bands"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E1", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"ekc", "+", "ekf"}], "2"], "+", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"ekc", "-", "ekf"}], "2"], ")"}], "2"], "+", 
        SuperscriptBox["m", "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E2", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"ekc", "+", "ekf"}], "2"], "-", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"ekc", "-", "ekf"}], "2"], ")"}], "2"], "+", 
        SuperscriptBox["m", "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Delta]", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ac", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "1"}], "\[Pi]"], 
      RowBox[{"Im", "[", 
       FractionBox[
        RowBox[{"\[Omega]", "-", "ekf", "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Delta]"}]}], 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "-", "ekf", "+", 
            RowBox[{"\[ImaginaryI]", " ", "\[Delta]"}]}], ")"}], 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "-", "ekc", "+", 
            RowBox[{"\[ImaginaryI]", " ", "\[Delta]"}]}], ")"}]}], "-", 
         SuperscriptBox["m", "2"], " "}]], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"enlevel", "=", "0.0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"ContourPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"E1", "\[Equal]", "enlevel"}], ",", 
          RowBox[{"E2", "\[Equal]", "enlevel"}], ",", 
          RowBox[{"ekc", "\[Equal]", "enlevel"}], ",", 
          RowBox[{"ekf", "\[Equal]", "enlevel"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"kx", ",", 
          RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ky", ",", 
          RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
        RowBox[{"ContourStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", "Blue", ",", 
           RowBox[{"{", "Red", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Black", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"LabelStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"20", ",", 
           RowBox[{"FontFamily", "\[Rule]", "\"\<Latin Modern Roman\>\""}]}], 
          "]"}]}], ",", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
          "\"\<\\!\\(\\*SubscriptBox[\\(k\\), \\(x\\)]\\)\>\"", ",", 
           "\"\<\\!\\(\\*SubscriptBox[\\(k\\), \\(y\\)]\\)\>\""}], "}"}]}], 
        ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"Axes", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True"}], "}"}]}], ",", 
        RowBox[{"FrameStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{
