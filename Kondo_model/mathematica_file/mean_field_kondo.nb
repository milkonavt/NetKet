          RowBox[{"ekc", "-", "ekf"}], "2"], ")"}], "2"], "+", 
       SuperscriptBox["\[Phi]", "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"8.61", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]], " ", "240"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nf", "[", "x_", "]"}], ":=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     RowBox[{"Exp", "[", 
      RowBox[{"x", "/", "T"}], "]"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nb", "[", "x_", "]"}], ":=", 
