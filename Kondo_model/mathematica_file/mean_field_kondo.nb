         RowBox[{"Cos", "[", 
          RowBox[{"2", "kx"}], "]"}], "+", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "ky"}], "]"}]}], ")"}]}], "-", 
      RowBox[{"4", "tc3", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"2", "kx"}], "]"}], 
          RowBox[{"Cos", "[", "ky", "]"}]}], "+", 
         RowBox[{
          RowBox[{"Cos", "[", "kx", "]"}], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "ky"}], "]"}]}]}], ")"}]}], "-", "\[Mu]c"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ekf", "=", 
     RowBox[{
      RowBox[{"ekc", "/.", 
       RowBox[{"kx", "->", 
        RowBox[{"kx", "+", "\[Pi]"}]}]}], "/.", 
      RowBox[{"ky", "->", 
       RowBox[{"ky", "+", "\[Pi]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", "0.25"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"hybridized", " ", "bands"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E1", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"ekc", "+", "ekf"}], "2"], "+", 
      SqrtBox[
